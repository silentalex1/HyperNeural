<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Connect Account HyperNeural</title>
<link rel="stylesheet" href="/style.css">
<style>
body {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.connect-container {
  background: white;
  padding: 40px;
  border-radius: 12px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  text-align: center;
  max-width: 400px;
  width: 90%;
}
.connect-container h1 {
  color: #333;
  margin-bottom: 10px;
}
.connect-container p {
  color: #666;
  margin-bottom: 30px;
}
.connect-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  padding: 15px 40px;
  font-size: 16px;
  border-radius: 8px;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  font-weight: 600;
}
.connect-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
}
.connect-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}
.login-link {
  display: block;
  margin-top: 20px;
  color: #667eea;
  text-decoration: none;
  font-weight: 500;
}
.login-link:hover {
  text-decoration: underline;
}
.status {
  margin-top: 20px;
  padding: 10px;
  border-radius: 6px;
  font-size: 14px;
}
.status.success {
  background: #d4edda;
  color: #155724;
}
.status.error {
  background: #f8d7da;
  color: #721c24;
}
</style>
</head>
<body>
<div class="connect-container">
  <h1>Connect Your Account</h1>
  <p>Link your HyperNeural account to deploy models</p>
  
  <button id="connectBtn" class="connect-btn">Connect Account</button>
  <a href="/auth/auth.html" class="login-link">Login to HyperNeural</a>
  
  <div id="status" class="status" style="display: none;"></div>
</div>

<script>
const connectBtn = document.getElementById('connectBtn');
const statusDiv = document.getElementById('status');

connectBtn.addEventListener('click', async () => {
  try {
    const response = await fetch('/api/connect/account', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      }
    });
    
    const data = await response.json();
    
    if (response.ok) {
      statusDiv.textContent = 'Account connected! Go back to console.';
      statusDiv.className = 'status success';
      statusDiv.style.display = 'block';
      connectBtn.textContent = 'Connected';
      connectBtn.disabled = true;
      
      const connectionData = {
        username: data.username,
        api_key: data.api_key,
        connected_at: new Date().toISOString()
      };
      
      const blob = new Blob([JSON.stringify(connectionData, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'hyperneural_config.json';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      
      statusDiv.textContent = 'Account connected! Config file downloaded. Place it in ~/.hyperneural/config.json';
    } else {
      statusDiv.textContent = data.error || 'Connection failed. Please login first.';
      statusDiv.className = 'status error';
      statusDiv.style.display = 'block';
    }
  } catch (error) {
    statusDiv.textContent = 'Connection failed. Please try again.';
    statusDiv.className = 'status error';
    statusDiv.style.display = 'block';
  }
});
</script>
</body>
</html>
